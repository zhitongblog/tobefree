---
interface Props {
  size?: number;
}
const { size = 30 } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 64 64"
  role="img"
  aria-label="To Be Free"
  class="tbf-logo"
>
  <rect width="64" height="64" rx="15" fill="#2e9e6b" />
  <path
    d="M16 40c8 2 15-1 20-8 2-3 5-6 9-6-2 4-2 7-5 10-5 6-14 9-24 8-1 0-1-3 0-4z"
    fill="#fff"
  />
  <path d="M34 25c3-4 8-6 13-5-2 2-2 4-5 6-3 2-6 2-8 1z" fill="#fff" opacity="0.88" />
  <circle cx="44" cy="24" r="1.6" fill="#1c8457" />
</svg>

<style>
  .tbf-logo {
    display: block;
    border-radius: 8px;
    box-shadow: var(--shadow-sm);
    flex-shrink: 0;
  }
</style>
