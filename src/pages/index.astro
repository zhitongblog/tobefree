---
// Fallback only. On Cloudflare the edge Function at functions/index.js handles
// "/" with a real server-side, language-aware 302 (no visible interstitial).
// This static page is only reached if that Function is unavailable.
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content="0; url=/zh/" />
    <link rel="canonical" href="https://tobefree.app/zh/" />
    <script is:inline>
      location.replace(
        '/' + ((navigator.language || 'zh').toLowerCase().indexOf('zh') === 0 ? 'zh' : 'en') + '/',
      );
    </script>
  </head>
  <body></body>
</html>
