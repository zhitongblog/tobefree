---
import { marked } from 'marked';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolCard from '../../../components/ToolCard.astro';
import {
  SITE,
  badgeById,
  platformById,
  categoryById,
  pick,
  type Locale,
} from '../../../consts';
import { locales, useTranslations, localizedPath, type Lang } from '../../../i18n/utils';
import { getAllTools, related } from '../../../lib/tools';

export async function getStaticPaths() {
  const tools = await getAllTools();
  return locales.flatMap((lang) =>
    tools.map((tool) => ({ params: { lang, slug: tool.id }, props: { lang, tool } })),
  );
}

const { lang, tool } = Astro.props as { lang: Lang; tool: Awaited<ReturnType<typeof getAllTools>>[number] };
const loc = lang as Locale;
const t = useTranslations(lang);
const d = tool.data;

const all = await getAllTools();
const rel = related(all, tool);

const cat = categoryById[d.category];
const initials = d.initials ?? d.name.replace(/[^A-Za-z0-9一-龥]/g, '').slice(0, 2).toUpperCase();
const reviewHtml = d.review ? marked.parse(pick(d.review, loc), { async: false }) : '';
const pageTitle =
  lang === 'zh'
    ? `${d.name} 免费软件推荐`
    : `${d.name} Free Software Review`;
const pageDescription =
  lang === 'zh'
    ? `${d.name} 是一款${d.price === 'free' ? '免费' : '有免费版'}的${cat ? pick(cat.label, loc) : '软件工具'}：${pick(d.description, loc)}`
    : `${d.name} is a ${d.price === 'free' ? 'free' : 'free-tier'} ${cat ? pick(cat.label, loc) : 'software tool'}: ${pick(d.description, loc)}`;

const abs = (p: string) => new URL(p, SITE.url).href;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: d.name,
    description: pick(d.description, loc),
    applicationCategory: cat ? pick(cat.label, 'en') : 'Utility',
    operatingSystem: d.platforms.join(', '),
    url: d.website,
    ...(d.license ? { license: d.license } : {}),
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    isAccessibleForFree: true,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: t('nav.home'), item: abs(localizedPath(lang, '')) },
      { '@type': 'ListItem', position: 2, name: t('nav.tools'), item: abs(localizedPath(lang, 'tools')) },
      { '@type': 'ListItem', position: 3, name: d.name, item: abs(localizedPath(lang, `tools/${tool.id}`)) },
    ],
  },
];
---

<BaseLayout title={pageTitle} description={pageDescription} jsonLd={jsonLd}>
  <article class="tool container">
    <a class="back" href={localizedPath(lang, 'tools')}>← {t('tool.back')}</a>

    <header class="head" style={`--card-accent:${d.accent}`}>
      <span class="avatar" aria-hidden="true">{initials}</span>
      <div class="head-main">
        <div class="titleline">
          <h1>{d.name}</h1>
          {d.selfMade && <span class="tag-self">✦ {t('card.selfmade')}</span>}
          <span class="tag-price">{d.price === 'free' ? t('card.free') : t('card.freemium')}</span>
        </div>
        <p class="tagline">{pick(d.tagline, loc)}</p>
        <div class="badges">
          {d.badges.map((b) => {
            const badge = badgeById[b];
            return badge ? (
              <span class="badge"><span aria-hidden="true">{badge.icon}</span> {pick(badge.label, loc)}</span>
            ) : null;
          })}
        </div>
      </div>
    </header>

    <div class="body">
      <div class="main">
        <p class="overview">{pick(d.description, loc)}</p>
        {reviewHtml && (
          <section class="review">
            <h2>{t('tool.why')}</h2>
            <div class="prose" set:html={reviewHtml} />
          </section>
        )}
      </div>

      <aside class="aside">
        <div class="cta-card" style={`--card-accent:${d.accent}`}>
          <a class="btn btn-primary full" href={d.website} target="_blank" rel="noopener">
            {t('tool.visit')} ↗
          </a>
          {d.download && d.download !== d.website && (
            <a class="btn btn-ghost full" href={d.download} target="_blank" rel="noopener">
              {loc === 'zh' ? '官方下载' : 'Download'} ↓
            </a>
          )}
          {d.repo && (
            <a class="btn btn-ghost full" href={d.repo} target="_blank" rel="noopener">
              {t('tool.source')} ⌥
            </a>
          )}
        </div>

        <dl class="details">
          <dt>{t('tool.category')}</dt>
          <dd>
            <a href={localizedPath(lang, `category/${d.category}`)}>
              {cat?.icon} {cat ? pick(cat.label, loc) : d.category}
            </a>
          </dd>
          <dt>{t('tool.license')}</dt>
          <dd>{d.license || '—'}</dd>
          <dt>{t('tool.platforms')}</dt>
          <dd class="platforms">
            {d.platforms.map((p) => {
              const pf = platformById[p];
              return pf ? <span>{pf.icon} {pick(pf.label, loc)}</span> : null;
            })}
          </dd>
          <dt>{t('tool.added')}</dt>
          <dd>{d.added}</dd>
          {d.tags.length > 0 && (
            <>
              <dt>{t('tool.tags')}</dt>
              <dd class="tags">{d.tags.map((tag) => <span>#{tag}</span>)}</dd>
            </>
          )}
        </dl>
      </aside>
    </div>

    {rel.length > 0 && (
      <section class="related">
        <h2>{t('tool.related')}</h2>
        <div class="grid cards-grid">
          {rel.map((r) => <ToolCard tool={r} lang={lang} />)}
        </div>
      </section>
    )}
  </article>
</BaseLayout>

<style>
  .tool {
    padding-block: 2rem 1rem;
  }
  .back {
    display: inline-block;
    color: var(--text-soft);
    font-weight: 600;
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }
  .back:hover {
    color: var(--accent-ink);
  }
  .head {
    display: flex;
    gap: 1.4rem;
    align-items: flex-start;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }
  .avatar {
    display: grid;
    place-items: center;
    width: 72px;
    height: 72px;
    flex-shrink: 0;
    border-radius: 18px;
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 1.7rem;
    color: #fff;
    background: linear-gradient(145deg, var(--card-accent), color-mix(in srgb, var(--card-accent) 68%, #000));
    box-shadow: var(--shadow-md);
  }
  .titleline {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    flex-wrap: wrap;
  }
  .titleline h1 {
    font-size: clamp(1.8rem, 5vw, 2.6rem);
  }
  .tag-self {
    font-size: 0.72rem;
    font-weight: 700;
    color: #fff;
    background: var(--accent);
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
  }
  .tag-price {
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--green);
    background: var(--green-soft);
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
  }
  .tagline {
    color: var(--text-soft);
    font-size: 1.1rem;
    margin-top: 0.5rem;
  }
  .badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: 1rem;
  }
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text-soft);
    background: var(--surface-2);
    border: 1px solid var(--border-soft);
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
  }

  .body {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 2.5rem;
    margin-top: 2rem;
    align-items: start;
  }
  .overview {
    font-size: 1.12rem;
    color: var(--text);
    line-height: 1.75;
  }
  .review {
    margin-top: 2rem;
  }
  .review h2 {
    font-size: 1.4rem;
    margin-bottom: 0.8rem;
  }
  .prose :global(p) {
    margin-bottom: 1rem;
    color: var(--text-soft);
    line-height: 1.85;
  }
  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--surface-2);
    padding: 0.1em 0.4em;
    border-radius: 5px;
    color: var(--accent-ink);
  }

  .cta-card {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 1.2rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
  }
  .full {
    width: 100%;
    justify-content: center;
  }
  .details {
    margin-top: 1.4rem;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.55rem 1rem;
    font-size: 0.92rem;
    padding: 1.2rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }
  .details dt {
    color: var(--text-faint);
    font-weight: 600;
  }
  .details dd {
    color: var(--text);
  }
  .platforms,
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .tags span {
    color: var(--text-soft);
    font-size: 0.85rem;
  }

  .related {
    margin-top: 3.5rem;
  }
  .related h2 {
    font-size: 1.4rem;
    margin-bottom: 1.2rem;
  }

  @media (max-width: 820px) {
    .body {
      grid-template-columns: 1fr;
    }
    .aside {
      order: -1;
    }
  }
</style>
