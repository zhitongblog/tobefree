---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolCard from '../../../components/ToolCard.astro';
import { CATEGORIES, pick, categoryById, type Locale } from '../../../consts';
import { useTranslations, type Lang } from '../../../i18n/utils';
import { getAllTools, localePaths } from '../../../lib/tools';

export function getStaticPaths() {
  return localePaths();
}

const { lang } = Astro.props as { lang: Lang };
const loc = lang as Locale;
const t = useTranslations(lang);
const all = await getAllTools();

// Only show categories that actually have tools.
const usedCats = CATEGORIES.filter((c) => all.some((x) => x.data.category === c.id));

function searchString(tool: (typeof all)[number]): string {
  const d = tool.data;
  const cat = categoryById[d.category];
  return [
    d.name,
    pick(d.tagline, loc),
    pick(d.description, loc),
    d.tags.join(' '),
    cat ? pick(cat.label, loc) : '',
  ]
    .join(' ')
    .toLowerCase();
}
---

<BaseLayout title={t('tools.title')} description={t('site.description')}>
  <section class="section container">
    <div class="section-head">
      <p class="eyebrow">{t('site.name')}</p>
      <h2>{t('tools.title')}</h2>
      <p>{t('tools.count', { n: all.length })}</p>
    </div>

    <div class="controls">
      <div class="search">
        <span aria-hidden="true">🔍</span>
        <input id="tool-search" type="search" placeholder={t('search.placeholder')} autocomplete="off" />
      </div>
      <div class="chips" role="tablist">
        <button class="chip active" data-cat="all">{lang === 'zh' ? '全部' : 'All'}</button>
        {usedCats.map((c) => (
          <button class="chip" data-cat={c.id}>
            <span aria-hidden="true">{c.icon}</span> {pick(c.label, loc)}
          </button>
        ))}
      </div>
    </div>

    <ul id="tool-grid" class="grid cards-grid tool-list">
      {all.map((tool) => (
        <li class="tool-item" data-category={tool.data.category} data-search={searchString(tool)}>
          <ToolCard tool={tool} lang={lang} />
        </li>
      ))}
    </ul>
    <p id="empty" class="empty" hidden>{t('search.empty')}</p>
  </section>
</BaseLayout>

<style>
  .controls {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .search {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.2rem 1.1rem;
    max-width: 420px;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .search:focus-within {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-soft);
  }
  .search input {
    border: 0;
    background: transparent;
    font: inherit;
    color: var(--text);
    padding: 0.6rem 0;
    width: 100%;
    outline: none;
  }
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .chip {
    font: inherit;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--text-soft);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.4rem 0.9rem;
    cursor: pointer;
    transition: color 0.15s, background-color 0.15s, border-color 0.15s;
  }
  .chip:hover {
    color: var(--text);
    border-color: var(--accent);
  }
  .chip.active {
    color: #fff;
    background: var(--accent);
    border-color: var(--accent);
  }
  .tool-list {
    list-style: none;
  }
  .tool-item.hidden {
    display: none;
  }
  .empty {
    text-align: center;
    color: var(--text-faint);
    padding: 3rem 0;
  }
</style>

<script>
  const search = document.getElementById('tool-search') as HTMLInputElement | null;
  const empty = document.getElementById('empty');
  const chips = Array.from(document.querySelectorAll<HTMLButtonElement>('.chip'));
  const items = Array.from(document.querySelectorAll<HTMLLIElement>('.tool-item'));
  let activeCat = 'all';

  function apply() {
    const q = (search?.value || '').trim().toLowerCase();
    let visible = 0;
    for (const item of items) {
      const matchCat = activeCat === 'all' || item.dataset.category === activeCat;
      const matchText = !q || (item.dataset.search || '').includes(q);
      const show = matchCat && matchText;
      item.classList.toggle('hidden', !show);
      if (show) visible++;
    }
    if (empty) empty.hidden = visible !== 0;
  }

  search?.addEventListener('input', apply);
  for (const chip of chips) {
    chip.addEventListener('click', () => {
      chips.forEach((c) => c.classList.remove('active'));
      chip.classList.add('active');
      activeCat = chip.dataset.cat || 'all';
      apply();
    });
  }
</script>
