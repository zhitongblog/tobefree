---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolCard from '../../../components/ToolCard.astro';
import SkillCard from '../../../components/SkillCard.astro';
import { SITE, pick, type Locale } from '../../../consts';
import { locales, localizedPath, type Lang } from '../../../i18n/utils';
import { getAllCollectionPages } from '../../../lib/collections';
import { getAllTools } from '../../../lib/tools';
import { getAllSkills } from '../../../lib/skills';

export async function getStaticPaths() {
  const pages = await getAllCollectionPages();
  return locales.flatMap((lang) =>
    pages.map((page) => ({ params: { lang, slug: page.id }, props: { lang, page } })),
  );
}

const { lang, page } = Astro.props as {
  lang: Lang;
  page: Awaited<ReturnType<typeof getAllCollectionPages>>[number];
};
const loc = lang as Locale;
const title = pick(page.data.title, loc);
const description = pick(page.data.description, loc);
const intro = pick(page.data.intro, loc);
const criteria = page.data.criteria[loc] ?? page.data.criteria.zh;
const faq = page.data.faq[loc] ?? page.data.faq.zh;

const tools = await getAllTools();
const skills = await getAllSkills();
const toolById = new Map(tools.map((tool) => [tool.id, tool]));
const skillById = new Map(skills.map((skill) => [skill.id, skill]));
const selectedTools = page.data.tools.map((id) => toolById.get(id)).filter(Boolean) as typeof tools;
const selectedSkills = page.data.skills.map((id) => skillById.get(id)).filter(Boolean) as typeof skills;
const recommendationCount = selectedTools.length + selectedSkills.length;
const abs = (p: string) => new URL(p, SITE.url).href;

const itemListElement = [
  ...selectedTools.map((tool, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: tool.data.name,
    url: abs(localizedPath(lang, `tools/${tool.id}`)),
  })),
  ...selectedSkills.map((skill, i) => ({
    '@type': 'ListItem',
    position: selectedTools.length + i + 1,
    name: skill.data.name,
    url: abs(localizedPath(lang, `skills/${skill.id}`)),
  })),
];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: title,
    description,
    url: abs(localizedPath(lang, `collections/${page.id}`)),
    mainEntity: {
      '@type': 'ItemList',
      name: title,
      numberOfItems: recommendationCount,
      itemListElement,
    },
  },
  ...(faq.length > 0
    ? [{
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: faq.map(({ q, a }) => ({
          '@type': 'Question',
          name: q,
          acceptedAnswer: { '@type': 'Answer', text: a },
        })),
      }]
    : []),
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <article class="collection container section">
    <a class="back" href={localizedPath(lang, 'collections')}>
      ← {lang === 'zh' ? '返回专题清单' : 'Back to collections'}
    </a>

    <header class="hero-copy">
      <p class="eyebrow">{lang === 'zh' ? '免费软件专题' : 'Free Software Collection'}</p>
      <h1>{title}</h1>
      <p class="lede">{intro}</p>
      <p class="count">
        {recommendationCount}
        {' '}
        {lang === 'zh' ? '个精选推荐' : 'curated recommendations'}
      </p>
    </header>

    {criteria.length > 0 && (
      <section class="criteria">
        <h2>{lang === 'zh' ? '怎么挑' : 'Selection Criteria'}</h2>
        <ul>
          {criteria.map((item) => <li>{item}</li>)}
        </ul>
      </section>
    )}

    {selectedTools.length > 0 && (
      <section class="recommendations">
        <div class="section-head compact">
          <h2>{lang === 'zh' ? '推荐工具' : 'Recommended Tools'}</h2>
        </div>
        <div class="grid cards-grid">
          {selectedTools.map((tool) => <ToolCard tool={tool} lang={lang} />)}
        </div>
      </section>
    )}

    {selectedSkills.length > 0 && (
      <section class="recommendations">
        <div class="section-head compact">
          <h2>{lang === 'zh' ? '推荐 Skills & MCP' : 'Recommended Skills & MCP'}</h2>
        </div>
        <div class="grid cards-grid">
          {selectedSkills.map((skill) => <SkillCard skill={skill} lang={lang} />)}
        </div>
      </section>
    )}

    {faq.length > 0 && (
      <section class="faq">
        <h2>{lang === 'zh' ? '常见问题' : 'FAQ'}</h2>
        <dl>
          {faq.map(({ q, a }) => (
            <div class="qa">
              <dt>{q}</dt>
              <dd>{a}</dd>
            </div>
          ))}
        </dl>
      </section>
    )}
  </article>
</BaseLayout>

<style>
  .collection {
    max-width: 1120px;
  }
  .back {
    display: inline-block;
    color: var(--text-soft);
    font-weight: 600;
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }
  .back:hover {
    color: var(--accent-ink);
  }
  .hero-copy {
    max-width: 780px;
    margin-bottom: 2rem;
  }
  .hero-copy h1 {
    font-size: clamp(2.1rem, 5vw, 3.4rem);
    line-height: 1.08;
  }
  .lede {
    color: var(--text-soft);
    font-size: 1.08rem;
    line-height: 1.75;
    margin-top: 1rem;
  }
  .count {
    color: var(--text-faint);
    font-weight: 700;
    margin-top: 0.8rem;
  }
  .criteria {
    padding: 1.2rem 1.4rem;
    margin: 2rem 0 2.8rem;
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: var(--radius);
    background: var(--surface);
  }
  .criteria h2,
  .faq h2 {
    font-size: 1.25rem;
    margin-bottom: 0.9rem;
  }
  .criteria ul {
    display: grid;
    gap: 0.6rem;
    padding-left: 1.2rem;
    color: var(--text-soft);
    line-height: 1.7;
  }
  .recommendations {
    margin-top: 2.6rem;
  }
  .compact {
    margin-bottom: 1.1rem;
  }
  .compact h2 {
    font-size: 1.45rem;
  }
  .faq {
    max-width: 820px;
    margin-top: 3rem;
  }
  .faq dl {
    display: grid;
    gap: 0.8rem;
  }
  .qa {
    padding: 1rem 1.15rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }
  .qa dt {
    color: var(--text);
    font-weight: 700;
    margin-bottom: 0.35rem;
  }
  .qa dd {
    color: var(--text-soft);
    line-height: 1.7;
  }
</style>
