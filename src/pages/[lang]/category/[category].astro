---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolCard from '../../../components/ToolCard.astro';
import { SITE, CATEGORIES, CATEGORY_SEO, categoryById, pick, type Locale } from '../../../consts';
import { locales, useTranslations, localizedPath, type Lang } from '../../../i18n/utils';
import { getAllTools, inCategory } from '../../../lib/tools';

export async function getStaticPaths() {
  return locales.flatMap((lang) =>
    CATEGORIES.map((c) => ({ params: { lang, category: c.id }, props: { lang, category: c.id } })),
  );
}

const { lang, category } = Astro.props as { lang: Lang; category: string };
const loc = lang as Locale;
const t = useTranslations(lang);
const cat = categoryById[category];

const all = await getAllTools();
const tools = inCategory(all, category);

const abs = (p: string) => new URL(p, SITE.url).href;
const catName = cat ? pick(cat.label, loc) : category;
const seo = category in CATEGORY_SEO ? CATEGORY_SEO[category as keyof typeof CATEGORY_SEO] : undefined;
const pageTitle = seo ? pick(seo.title, loc) : catName;
const pageDescription = seo
  ? pick(seo.description, loc)
  : `${catName} · ${t('site.description')}`;
const intro = seo ? pick(seo.intro, loc) : pageDescription;
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: t('nav.home'), item: abs(localizedPath(lang, '')) },
      { '@type': 'ListItem', position: 2, name: t('nav.tools'), item: abs(localizedPath(lang, 'tools')) },
      { '@type': 'ListItem', position: 3, name: catName, item: abs(localizedPath(lang, `category/${category}`)) },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: pageTitle,
    description: pageDescription,
    url: abs(localizedPath(lang, `category/${category}`)),
    mainEntity: {
      '@type': 'ItemList',
      name: catName,
      numberOfItems: tools.length,
      itemListElement: tools.map((tl, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: tl.data.name,
        url: abs(localizedPath(lang, `tools/${tl.id}`)),
      })),
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: pageTitle,
    numberOfItems: tools.length,
    itemListElement: tools.map((tl, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: tl.data.name,
      url: abs(localizedPath(lang, `tools/${tl.id}`)),
    })),
  },
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  jsonLd={jsonLd}
>
  <section class="section container">
    <a class="back" href={localizedPath(lang, 'tools')}>← {t('tool.back')}</a>
    <div class="section-head">
      <p class="eyebrow">{t('nav.categories')}</p>
      <h1>{cat?.icon} {pageTitle}</h1>
      <p>{intro}</p>
      <p class="count">{t('tools.count', { n: tools.length })}</p>
    </div>

    {tools.length > 0 ? (
      <div class="grid cards-grid">
        {tools.map((tool) => <ToolCard tool={tool} lang={lang} />)}
      </div>
    ) : (
      <p class="empty">{t('tools.empty')}</p>
    )}
  </section>
</BaseLayout>

<style>
  .back {
    display: inline-block;
    color: var(--text-soft);
    font-weight: 600;
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }
  .back:hover {
    color: var(--accent-ink);
  }
  .empty {
    color: var(--text-faint);
    padding: 2rem 0;
  }
  .section-head h1 {
    font-size: clamp(2rem, 5vw, 3rem);
  }
  .count {
    color: var(--text-faint) !important;
    font-size: 0.92rem;
    margin-top: 0.45rem;
  }
</style>
