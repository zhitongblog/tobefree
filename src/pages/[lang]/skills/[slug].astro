---
import { marked } from 'marked';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SkillCard from '../../../components/SkillCard.astro';
import { SITE, badgeById, skillKindById, pick, type Locale } from '../../../consts';
import { locales, useTranslations, localizedPath, type Lang } from '../../../i18n/utils';
import { getAllSkills, relatedSkills } from '../../../lib/skills';

export async function getStaticPaths() {
  const items = await getAllSkills();
  return locales.flatMap((lang) =>
    items.map((skill) => ({ params: { lang, slug: skill.id }, props: { lang, skill } })),
  );
}

const { lang, skill } = Astro.props as {
  lang: Lang;
  skill: Awaited<ReturnType<typeof getAllSkills>>[number];
};
const loc = lang as Locale;
const t = useTranslations(lang);
const d = skill.data;

const all = await getAllSkills();
const rel = relatedSkills(all, skill);
const kind = skillKindById[d.kind];
const initials = d.initials ?? d.name.replace(/[^A-Za-z0-9]/g, '').slice(0, 2).toUpperCase();
const reviewHtml = d.review ? marked.parse(pick(d.review, loc), { async: false }) : '';
const copyLabel = lang === 'zh' ? '复制' : 'Copy';
const copiedLabel = lang === 'zh' ? '已复制' : 'Copied';

const abs = (p: string) => new URL(p, SITE.url).href;
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: d.name,
    description: pick(d.description, loc),
    applicationCategory: 'DeveloperApplication',
    url: d.website,
    ...(d.license ? { license: d.license } : {}),
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    isAccessibleForFree: true,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: t('nav.home'), item: abs(localizedPath(lang, '')) },
      { '@type': 'ListItem', position: 2, name: t('skills.title'), item: abs(localizedPath(lang, 'skills')) },
      { '@type': 'ListItem', position: 3, name: d.name, item: abs(localizedPath(lang, `skills/${skill.id}`)) },
    ],
  },
];
---

<BaseLayout title={d.name} description={pick(d.description, loc)} jsonLd={jsonLd}>
  <article class="tool container">
    <a class="back" href={localizedPath(lang, 'skills')}>← {t('skills.back')}</a>

    <header class="head" style={`--card-accent:${d.accent}`}>
      <span class="avatar" aria-hidden="true">{initials}</span>
      <div class="head-main">
        <div class="titleline">
          <h1>{d.name}</h1>
          {d.selfMade && <span class="tag-self">✦ {t('card.selfmade')}</span>}
          <span class="tag-kind">{kind?.icon} {kind ? pick(kind.label, loc) : d.kind}</span>
        </div>
        <p class="tagline">{pick(d.tagline, loc)}</p>
        <div class="badges">
          {d.badges.map((b) => {
            const badge = badgeById[b];
            return badge ? (
              <span class="badge"><span aria-hidden="true">{badge.icon}</span> {pick(badge.label, loc)}</span>
            ) : null;
          })}
        </div>
      </div>
    </header>

    <div class="body">
      <div class="main">
        <p class="overview">{pick(d.description, loc)}</p>
        {d.install && (
          <section class="install">
            <h2>{t('skills.install')}</h2>
            <div class="code-wrap">
              <pre><code>{d.install}</code></pre>
              <button class="copy-btn" type="button" data-copy={d.install} data-copied={copiedLabel}>
                {copyLabel}
              </button>
            </div>
          </section>
        )}
        {reviewHtml && (
          <section class="review">
            <h2>{t('tool.why')}</h2>
            <div class="prose" set:html={reviewHtml} />
          </section>
        )}
      </div>

      <aside class="aside">
        <div class="cta-card" style={`--card-accent:${d.accent}`}>
          <a class="btn btn-primary full" href={d.website} target="_blank" rel="noopener">
            {t('skills.visit')} ↗
          </a>
          {d.repo && (
            <a class="btn btn-ghost full" href={d.repo} target="_blank" rel="noopener">
              {t('skills.source')} ⌥
            </a>
          )}
        </div>

        <dl class="details">
          <dt>{lang === 'zh' ? '类型' : 'Type'}</dt>
          <dd>{kind?.icon} {kind ? pick(kind.label, loc) : d.kind}</dd>
          <dt>{t('tool.license')}</dt>
          <dd>{d.license || '—'}</dd>
          {d.clients.length > 0 && (
            <>
              <dt>{t('skills.clients')}</dt>
              <dd class="chips-list">{d.clients.map((cl) => <span>{cl}</span>)}</dd>
            </>
          )}
          <dt>{t('tool.added')}</dt>
          <dd>{d.added}</dd>
          {d.tags.length > 0 && (
            <>
              <dt>{t('tool.tags')}</dt>
              <dd class="tags">{d.tags.map((tag) => <span>#{tag}</span>)}</dd>
            </>
          )}
        </dl>
      </aside>
    </div>

    {rel.length > 0 && (
      <section class="related">
        <h2>{t('skills.related')}</h2>
        <div class="grid cards-grid">
          {rel.map((r) => <SkillCard skill={r} lang={lang} />)}
        </div>
      </section>
    )}
  </article>
</BaseLayout>

<style>
  .tool { padding-block: 2rem 1rem; }
  .back {
    display: inline-block;
    color: var(--text-soft);
    font-weight: 600;
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }
  .back:hover { color: var(--accent-ink); }
  .head {
    display: flex;
    gap: 1.4rem;
    align-items: flex-start;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }
  .avatar {
    display: grid;
    place-items: center;
    width: 72px;
    height: 72px;
    flex-shrink: 0;
    border-radius: 18px;
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 1.6rem;
    color: #fff;
    background: linear-gradient(145deg, var(--card-accent), color-mix(in srgb, var(--card-accent) 68%, #000));
    box-shadow: var(--shadow-md);
  }
  .titleline {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    flex-wrap: wrap;
  }
  .titleline h1 { font-size: clamp(1.8rem, 5vw, 2.6rem); }
  .tag-self {
    font-size: 0.72rem;
    font-weight: 700;
    color: #fff;
    background: var(--accent);
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
  }
  .tag-kind {
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--accent-ink);
    background: var(--accent-soft);
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
  }
  .tagline {
    color: var(--text-soft);
    font-size: 1.1rem;
    margin-top: 0.5rem;
  }
  .badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: 1rem;
  }
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text-soft);
    background: var(--surface-2);
    border: 1px solid var(--border-soft);
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
  }
  .body {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 2.5rem;
    margin-top: 2rem;
    align-items: start;
  }
  .overview {
    font-size: 1.12rem;
    color: var(--text);
    line-height: 1.75;
  }
  .install {
    margin-top: 1.6rem;
  }
  .install h2 {
    font-size: 1.1rem;
    margin-bottom: 0.6rem;
  }
  .code-wrap {
    position: relative;
  }
  .install pre {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.9rem 5.2rem 0.9rem 1rem;
    overflow-x: auto;
  }
  .install code {
    font-family: var(--font-mono);
    font-size: 0.88rem;
    color: var(--accent-ink);
  }
  .copy-btn {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    font: inherit;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text-soft);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.32rem 0.7rem;
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
  }
  .copy-btn:hover {
    color: var(--accent-ink);
    border-color: var(--accent);
  }
  .copy-btn.copied {
    color: var(--green);
    border-color: var(--green);
  }
  .review { margin-top: 2rem; }
  .review h2 { font-size: 1.4rem; margin-bottom: 0.8rem; }
  .prose :global(p) {
    margin-bottom: 1rem;
    color: var(--text-soft);
    line-height: 1.85;
  }
  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--surface-2);
    padding: 0.1em 0.4em;
    border-radius: 5px;
    color: var(--accent-ink);
  }
  .cta-card {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 1.2rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
  }
  .full { width: 100%; justify-content: center; }
  .details {
    margin-top: 1.4rem;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.55rem 1rem;
    font-size: 0.92rem;
    padding: 1.2rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }
  .details dt { color: var(--text-faint); font-weight: 600; }
  .details dd { color: var(--text); }
  .chips-list, .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .chips-list span {
    font-size: 0.8rem;
    background: var(--surface-2);
    border: 1px solid var(--border-soft);
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    color: var(--text-soft);
  }
  .tags span { color: var(--text-soft); font-size: 0.85rem; }
  .related { margin-top: 3.5rem; }
  .related h2 { font-size: 1.4rem; margin-bottom: 1.2rem; }
  @media (max-width: 820px) {
    .body { grid-template-columns: 1fr; }
    .aside { order: -1; }
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const text = btn.dataset.copy || '';
      try {
        await navigator.clipboard.writeText(text);
      } catch {
        const ta = document.createElement('textarea');
        ta.value = text;
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        ta.remove();
      }
      const done = btn.dataset.copied || 'Copied';
      const orig = btn.textContent;
      btn.textContent = done;
      btn.classList.add('copied');
      setTimeout(() => {
        btn.textContent = orig;
        btn.classList.remove('copied');
      }, 1500);
    });
  });
</script>
